# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Virtual environment
# =============================================================================
.venv/
venv/
env/
.env

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# IDE / editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# =============================================================================
# MLflow — all generated tracking data
# =============================================================================
mlruns/
mlartifacts/
mlflow.db

# =============================================================================
# Experiment results — everything produced by training or evaluation runs
# =============================================================================
experiments/results/

# =============================================================================
# Generated data files (streaming cache, derived datasets, splits, features)
# =============================================================================
data/cache/
data/quick_test/
data/test_cache_generation/
data/interim/
data/processed/
data/raw/
data/ml/datasets/
data/ml/features/
data/ml/splits/

# =============================================================================
# Model weights and serialised objects
# =============================================================================
*.pt
*.pth
*.pkl
*.ckpt
*.h5
*.hdf5
*.onnx
*.pb
*.npy
*.npz

# =============================================================================
# Model artifacts directories (produced during training)
# =============================================================================
models/artifacts/
artifacts/

# =============================================================================
# Plots, images, logs produced during runs
# =============================================================================
*.png
*.jpg
*.jpeg
*.pdf
*.svg
*.log

# =============================================================================
# Result / report JSON files produced during runs (not committed config JSONs)
# =============================================================================
pipeline_validation_results.json
gradient_flow_test_results.json

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Coverage / testing artefacts
# =============================================================================
.coverage
htmlcov/
.pytest_cache/
.tox/

# =============================================================================
# Keep — explicitly track README files inside otherwise-ignored directories
# =============================================================================
!data/README.md
!data/ml/README.md
!data/external/README.md
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/raw/.gitkeep
!data/ml/datasets/.gitkeep
!data/ml/features/.gitkeep
!data/ml/splits/.gitkeep
!experiments/results/.gitkeep
